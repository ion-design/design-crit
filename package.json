    "vite"
  ],
  "dependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-syntax-jsx": "^7.25.9",
    "@babel/preset-typescript": "^7.26.0",
    "@babel/types": "^7.26.0"
  }
}
