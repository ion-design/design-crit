{
  "name": "design-crit",
  "version": "0.1.0",
  "description": "Agent-requested app review sessions. Crit mirrors your app, records a narrated review with pointer + source-code context, and returns a merged timestamped transcript to the agent.",
  "license": "MIT",
  "author": "Samraaj Bath",
  "bin": {
    "crit": "bin/crit.js"
  },
  "files": [
    "bin/",
    "src/",
    "overlay/",
    "skill/",
    "ion-compiler/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test 'test/*.test.js'",
    "crit": "node bin/crit.js",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ion-design/design-crit.git"
  },
  "homepage": "https://github.com/ion-design/design-crit#readme",
  "bugs": {
    "url": "https://github.com/ion-design/design-crit/issues"
  },
  "keywords": [
    "design-review",
    "ai-agent",
